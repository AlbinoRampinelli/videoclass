generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  name              String?
  email             String?          @unique
  codigoVerificacao String?
  passwordHash      String?
  cpf               String?          @unique
  createdAt         DateTime         @default(now())
  phone             String?
  schoolName        String?
  userType          UserType         @default(RESPONSAVEL)
  image             String?
  emailVerified     DateTime?
  accounts          Account[]
  enrollments       Enrollment[]
  grades            Grade[]
  lessonProgress    LessonProgress[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  price       Float
  imageUrl    String?
  format      CourseFormat @default(ONLINE)
  duration    String?
  features    String[]
  isOpen      Boolean      @default(false)
  enrollments Enrollment[]
  modules     Module[]
}

model Enrollment {
  id        String    @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime  @default(now())
  status    String    @default("active")
  endDate   DateTime?
  course    Course    @relation(fields: [courseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Module {
  id         String      @id @default(cuid())
  courseId   String
  title      String
  order      Int
  videoUrl   String?
  pdfUrl     String?     @db.Text
  challenges Challenge[]
  grades     Grade[]
  lessons    Lesson[]
  course     Course      @relation(fields: [courseId], references: [id])
  videos     Video[]
}

model Lesson {
  id          String           @id @default(cuid())
  moduleId    String
  title       String
  content     String?
  description String?
  order       Int
  type        String
  url         String?
  module      Module           @relation(fields: [moduleId], references: [id])
  progress    LessonProgress[]
}

model LessonProgress {
  id        String  @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean @default(false)
  lesson    Lesson  @relation(fields: [lessonId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
}

model Grade {
  id            String  @id @default(cuid())
  userId        String
  moduleId      String
  theoryScore   Float   @default(0)
  practiceScore Float   @default(0)
  totalScore    Float   @default(0)
  isApproved    Boolean @default(false)
  module        Module  @relation(fields: [moduleId], references: [id])
  user          User    @relation(fields: [userId], references: [id])

  @@unique([userId, moduleId])
}

model Interest {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  cpf       String
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Lead {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  cpf       String   @unique
  whatsapp  String
  escola    String?
  cursoId   String?
  createdAt DateTime @default(now())
  status    String   @default("PENDENTE")
  userType  String?
}

model Challenge {
  id          String       @id @default(uuid())
  slug        String       @unique
  title       String
  description String
  initialCode String
  testCode    String
  expected    String
  courseSlug  String
  order       Int          @default(0)
  moduleId    String?
  videoId     String?
  module      Module?      @relation(fields: [moduleId], references: [id])
  video       Video?       @relation(fields: [videoId], references: [id])
  submissions Submission[]
}

model Submission {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  grade       Float
  code        String
  feedback    String?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  Video       Video?    @relation(fields: [videoId], references: [id])
  videoId     String?
}

model Video {
  id             String       @id @default(cuid())
  title          String
  url            String?
  description    String?
  order          Int          @default(0)
  initialCode    String?      @db.Text
  expectedOutput String?      @db.Text
  pdfUrl         String?      @db.Text
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  submissions    Submission[]
  challenges     Challenge[]
}

enum CourseFormat {
  ONLINE
  PRESENCIAL
}

enum UserType {
  ALUNO
  RESPONSAVEL
  PROFESSOR
  OUTRO
  ADMIN
}
